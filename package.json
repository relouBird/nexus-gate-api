{
  "name": "nexus-gate-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api-gateway/test/jest-e2e.json",
    "db:auth:generate": "prisma generate --config apps/auth-service/prisma.config.ts",
    "db:auth:format": "prisma format --schema=apps/auth-service/prisma/schema.prisma",
    "db:auth:studio": "prisma studio --config apps/auth-service/prisma.config.ts",
    "db:auth:migrate": "prisma migrate dev --name init --config apps/auth-service/prisma.config.ts",
    "db:auth:reset": "prisma migrate reset --config apps/auth-service/prisma.config.ts",
    "db:user:generate": "prisma generate --config apps/user-service/prisma.config.ts",
    "db:user:format": "prisma format --schema=apps/user-service/prisma/schema.prisma",
    "db:user:studio": "prisma studio --config apps/user-service/prisma.config.ts",
    "db:user:migrate": "prisma migrate dev --name init --config apps/user-service/prisma.config.ts",
    "db:user:reset": "prisma migrate reset --config apps/user-service/prisma.config.ts",
    "db:configuration:generate": "prisma generate --config apps/configuration-service/prisma.config.ts",
    "db:configuration:format": "prisma format --schema=apps/configuration-service/prisma/schema.prisma",
    "db:configuration:studio": "prisma studio --config apps/configuration-service/prisma.config.ts",
    "db:configuration:migrate": "prisma migrate dev --name init --config apps/configuration-service/prisma.config.ts",
    "db:configuration:reset": "prisma migrate reset --config apps/configuration-service/prisma.config.ts",
    "start:auth-service": "nest start --watch auth-service",
    "start:user-service": "nest start --watch user-service",
    "start:configuration-service": "nest start --watch configuration-service",
    "start:gateway": "nest start --watch api-gateway"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.24",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^7.8.0",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.0.0",
    "dotenv": "^17.4.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
